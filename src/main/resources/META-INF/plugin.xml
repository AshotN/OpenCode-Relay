<idea-plugin>
    <id>com.ashotn.opencode-intellij</id>
    <name>OpenCode</name>
    <vendor>Ashot Nazaryan</vendor>
    <resource-bundle>messages.OpenCodeBundle</resource-bundle>

    <description><![CDATA[
        OpenCode AI coding assistant integration for IntelliJ IDEA.
        Brings the power of OpenCode directly into your IDE.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="OpenCode"
            anchor="right"
            factoryClass="com.ashotn.opencode.toolwindow.OpenCodeToolWindowFactory"
            icon="/icons/opencode.svg"
        />
        <projectConfigurable
            parentId="tools"
            instance="com.ashotn.opencode.settings.OpenCodeSettingsConfigurable"
            id="com.ashotn.opencode.settings"
            key="configurable.opencode.displayName"
        />
        <notificationGroup id="OpenCode" displayType="BALLOON" key="notification.group.opencode"/>
    </extensions>

    <actions>
        <!-- Actions registered programmatically via toolWindow.setTitleActions() -->

        <action
            id="com.ashotn.opencode.actions.ClearInstanceAction"
            class="com.ashotn.opencode.actions.ClearInstanceAction">
            <!-- Global shortcut when panel is not focused -->
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift ESCAPE"/>
        </action>

        <action
            id="com.ashotn.opencode.actions.SendSelectionAction"
            class="com.ashotn.opencode.actions.SendSelectionAction">
            <keyboard-shortcut keymap="$default" first-keystroke="shift 4"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
