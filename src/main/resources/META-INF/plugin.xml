<idea-plugin>
    <id>com.ashotn.opencode-companion</id>
    <name>OpenCode Companion</name>
    <vendor>Ashot Nazaryan</vendor>
    <resource-bundle>messages.OpenCodeBundle</resource-bundle>

    <description><![CDATA[
        OpenCode Companion — AI coding assistant integration for IntelliJ IDEA.
        Brings the power of OpenCode directly into your IDE.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="withTerminal.xml">org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="OpenCode Companion"
            anchor="right"
            factoryClass="com.ashotn.opencode.companion.toolwindow.OpenCodeToolWindowFactory"
            icon="/icons/opencode.svg"
        />
        <projectConfigurable
            parentId="tools"
            instance="com.ashotn.opencode.companion.settings.OpenCodeSettingsConfigurable"
            id="com.ashotn.opencode.companion.settings"
            key="configurable.opencode.displayName"
        />
        <notificationGroup id="OpenCode Companion" displayType="BALLOON" key="notification.group.opencode"/>
    </extensions>

    <actions>
        <!-- Actions registered programmatically via toolWindow.setTitleActions() -->

        <action
            id="com.ashotn.opencode.companion.actions.ClearSelectedSessionAction"
            class="com.ashotn.opencode.companion.actions.ClearSelectedSessionAction">
            <!-- Global shortcut when panel is not focused -->
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift ESCAPE"/>
        </action>

        <action
            id="com.ashotn.opencode.companion.actions.SendSelectionAction"
            class="com.ashotn.opencode.companion.actions.SendSelectionAction">
            <keyboard-shortcut keymap="$default" first-keystroke="shift 4"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action
            id="com.ashotn.opencode.companion.actions.SendFileAction"
            class="com.ashotn.opencode.companion.actions.SendFileAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action
            id="com.ashotn.opencode.companion.actions.SendFolderAction"
            class="com.ashotn.opencode.companion.actions.SendFolderAction">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
