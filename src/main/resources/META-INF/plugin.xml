<idea-plugin>
    <id>com.ashotn.opencode-intellij</id>
    <name>OpenCode</name>
    <vendor>Ashot Nazaryan</vendor>

    <description><![CDATA[
        OpenCode AI coding assistant integration for IntelliJ IDEA.
        Brings the power of OpenCode directly into your IDE.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="OpenCode"
            anchor="right"
            factoryClass="com.ashotn.opencode.toolwindow.OpenCodeToolWindowFactory"
            icon="/icons/opencode.svg"
        />
        <projectService serviceImplementation="com.ashotn.opencode.OpenCodePlugin"/>
        <projectService serviceImplementation="com.ashotn.opencode.settings.OpenCodeSettings"/>
        <projectConfigurable
            parentId="tools"
            instance="com.ashotn.opencode.settings.OpenCodeSettingsConfigurable"
            id="com.ashotn.opencode.settings"
            displayName="OpenCode"
        />
        <notificationGroup id="OpenCode" displayType="BALLOON"/>

        <projectService serviceImplementation="com.ashotn.opencode.diff.OpenCodeDiffService"/>
        <projectService serviceImplementation="com.ashotn.opencode.diff.EditorDiffRenderer"/>
    </extensions>

    <actions>
        <!-- Actions registered programmatically via toolWindow.setTitleActions() -->

        <action
            id="com.ashotn.opencode.actions.ClearInstanceAction"
            class="com.ashotn.opencode.actions.ClearInstanceAction"
            text="Clear Session"
            description="Clear the selected session and remove all diff highlights">
            <!-- Global shortcut when panel is not focused -->
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift ESCAPE"/>
        </action>

        <action
            id="com.ashotn.opencode.actions.SendSelectionAction"
            class="com.ashotn.opencode.actions.SendSelectionAction"
            text="Send Selection to OpenCode"
            description="Append the selected code to the active OpenCode session's prompt input">
            <keyboard-shortcut keymap="$default" first-keystroke="shift 4"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
